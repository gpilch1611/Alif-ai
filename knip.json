{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": ["app.js", "data.js", "service-worker.js", "scripts/*.mjs", "tests/*.js"],
  "project": [
    "**/*.{js,mjs}",
    "!node_modules/**",
    "!playwright-report/**",
    "!test-results/**",
    "!.lighthouse-profile/**",
    "!lighthouse-report/**"
  ],
  "ignoreBinaries": ["npm.cmd"]
}
